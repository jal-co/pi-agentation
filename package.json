{
	"name": "pi-agentation",
	"version": "0.1.1",
	"description": "Pi extension that receives Agentation webhooks and turns them into queued user messages",
	"author": "Dennis Eijpe",
	"license": "MIT",
	"type": "module",
	"repository": "github:jal-co/pi-agentation",
	"bugs": "https://github.com/denniseijpe/pi-agentation/issues",
	"homepage": "https://github.com/denniseijpe/pi-agentation#readme",
	"keywords": [
		"pi-package",
		"pi-extension",
		"pi",
		"agentation"
	],
	"files": [
		"index.ts",
		"inject-entry.ts"
	],
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*"
	},
	"dependencies": {
		"agentation": "^3.0.2",
		"esbuild": "^0.25.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"scripts": {
		"pack:dry-run": "npm pack --dry-run"
	}
